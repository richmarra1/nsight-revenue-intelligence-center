# Copy this file to .env.local and fill in your real values.
# .env.local is already in .gitignore — never commit real credentials.

GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REFRESH_TOKEN=your-refresh-token-here
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback/google

# The Gmail address the brief gets sent TO (Michael Ciullo's inbox)
RECIPIENT_EMAIL=michael@nsighthealth.com

# Anthropic API key for live Claude calls (brief generation + risk explanations)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
